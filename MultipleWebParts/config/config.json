{
  "$schema": "https://developer.microsoft.com/json-schemas/spfx-build/config.2.0.schema.json",
  "version": "2.0",
  "bundles": {
    "multiplewebparts-web-part": {
      "components": [
        {
          "entrypoint": "./lib/webparts/multiplewebparts/MultiplewebpartsWebPart.js",
          "manifest": "./src/webparts/multiplewebparts/MultiplewebpartsWebPart.manifest.json"
        }
      ]
    },
    "helloworld-2-web-part": {
      "components": [
        {
          "entrypoint": "./lib/webparts/helloworld2/Helloworld2WebPart.js",
          "manifest": "./src/webparts/helloworld2/Helloworld2WebPart.manifest.json"
        }
      ]
    },
    "helloworld-3-web-part": {
      "components": [
        {
          "entrypoint": "./lib/webparts/helloworld3/Helloworld3WebPart.js",
          "manifest": "./src/webparts/helloworld3/Helloworld3WebPart.manifest.json"
        }
      ]
    },
    "display-site-details-web-part": {
      "components": [
        {
          "entrypoint": "./lib/webparts/displaySiteDetails/DisplaySiteDetailsWebPart.js",
          "manifest": "./src/webparts/displaySiteDetails/DisplaySiteDetailsWebPart.manifest.json"
        }
      ]
    }
  },
  "externals": {},
  "localizedResources": {
    "MultiplewebpartsWebPartStrings": "lib/webparts/multiplewebparts/loc/{locale}.js",
    "Helloworld2WebPartStrings": "lib/webparts/helloworld2/loc/{locale}.js",
    "Helloworld3WebPartStrings": "lib/webparts/helloworld3/loc/{locale}.js",
    "DisplaySiteDetailsWebPartStrings": "lib/webparts/displaySiteDetails/loc/{locale}.js"
  }
}
