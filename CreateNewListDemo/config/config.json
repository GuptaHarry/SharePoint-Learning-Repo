  },
  "externals": {},
  "localizedResources": {
    "NewListDemoWebPartStrings": "lib/webparts/newListDemo/loc/{locale}.js",
    "NewSubSiteDemoWebPartStrings": "lib/webparts/newSubSiteDemo/loc/{locale}.js"
  }
