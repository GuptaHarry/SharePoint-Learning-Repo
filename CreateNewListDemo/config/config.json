{
  "$schema": "https://developer.microsoft.com/json-schemas/spfx-build/config.2.0.schema.json",
  "version": "2.0",
  "bundles": {
    "new-list-demo-web-part": {
      "components": [
        {
          "entrypoint": "./lib/webparts/newListDemo/NewListDemoWebPart.js",
          "manifest": "./src/webparts/newListDemo/NewListDemoWebPart.manifest.json"
        }
      ]
    },
    "new-sub-site-demo-web-part": {
      "components": [
        {
          "entrypoint": "./lib/webparts/newSubSiteDemo/NewSubSiteDemoWebPart.js",
